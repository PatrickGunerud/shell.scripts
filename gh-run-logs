#!/usr/bin/env bash
set -euo pipefail

# gh-run-logs: interactive GitHub Actions run-log downloader
#
# Runtime Dependencies:
#   - gh >= 2.30 (must support: gh run list --json, gh run view --json)
#   - bash >= 4
#   - awk, sed, date (POSIX)
#
# Usage:
#   gh-run-logs
#   gh-run-logs -n 50
#   gh-run-logs -R owner/repo
#   gh-run-logs -w "Deploy - Chrony"
#   gh-run-logs -b main
#   gh-run-logs -o /path/to/dir
#   gh-run-logs --id 22526827104

OUT_DIR="${HOME}/Downloads"
LIMIT=20
REPO=""
WORKFLOW_FILTER=""
BRANCH_FILTER=""
RUN_ID=""

die() { echo "Error: $*" >&2; exit 1; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"; }

sanitize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g'
}

usage() {
  sed -n '1,140p' "$0" | sed -n 's/^# \{0,1\}//p'
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -o|--out) OUT_DIR="${2:-}"; shift 2 ;;
    -n|--limit) LIMIT="${2:-}"; shift 2 ;;
    -R|--repo) REPO="${2:-}"; shift 2 ;;
    -w|--workflow) WORKFLOW_FILTER="${2:-}"; shift 2 ;;
    -b|--branch) BRANCH_FILTER="${2:-}"; shift 2 ;;
    --id) RUN_ID="${2:-}"; shift 2 ;;
    -h|--help) usage ;;
    *) die "Unknown arg: $1 (use --help)" ;;
  esac
done

need_cmd gh
need_cmd awk
need_cmd sed
need_cmd date

mkdir -p "$OUT_DIR"

if ! gh auth status >/dev/null 2>&1; then
  die "gh is not authenticated. Run: gh auth login"
fi

# Build a gh command array (avoids brittle empty-array expansions under `set -u`)
ghcmd=(gh)
if [[ -n "$REPO" ]]; then
  ghcmd+=(-R "$REPO")
fi

get_repo_full() {
  # Prefer explicit -R. Otherwise ask gh for current repo context.
  if [[ -n "$REPO" ]]; then
    echo "$REPO"
    return 0
  fi

  # This works when you're inside a cloned repo with a GitHub remote.
  local r
  if r="$(gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null)"; then
    [[ -n "$r" ]] && { echo "$r"; return 0; }
  fi

  # Fallback: parse git remote origin (best-effort)
  if command -v git >/dev/null 2>&1; then
    local url
    url="$(git remote get-url origin 2>/dev/null || true)"
    if [[ -n "$url" ]]; then
      # Handle git@github.com:OWNER/REPO.git and https://github.com/OWNER/REPO(.git)
      url="${url%.git}"
      url="${url#git@github.com:}"
      url="${url#https://github.com/}"
      url="${url#http://github.com/}"
      if [[ "$url" == */* ]]; then
        echo "$url"
        return 0
      fi
    fi
  fi

  die "Could not determine repo. Run with -R owner/repo, or run inside a GitHub repo."
}

pick_run() {
  local tmp lines
  tmp="$(mktemp)"

  "${ghcmd[@]}" run list -L "$LIMIT" \
    --json databaseId,name,workflowName,headBranch,event,status,conclusion,createdAt \
    --jq '.[] | [
      (.databaseId|tostring),
      (.workflowName // ""),
      (.name // ""),
      (.headBranch // ""),
      (.event // ""),
      (.status // ""),
      (.conclusion // ""),
      (.createdAt // "")
    ] | @tsv' > "$tmp"

  [[ -s "$tmp" ]] || { rm -f "$tmp"; die "No runs returned."; }

  lines="$(cat "$tmp")"

  if [[ -n "$WORKFLOW_FILTER" ]]; then
    lines="$(printf '%s\n' "$lines" | awk -v q="$WORKFLOW_FILTER" 'BEGIN{IGNORECASE=1} index($2,q)>0')"
  fi
  if [[ -n "$BRANCH_FILTER" ]]; then
    lines="$(printf '%s\n' "$lines" | awk -v b="$BRANCH_FILTER" '$4==b')"
  fi

  [[ -n "$lines" ]] || { rm -f "$tmp"; die "No runs match your filters."; }

  echo
  echo "Select a run to download logs:"
  echo

  local i=0
  local ids=()
  while IFS=$'\t' read -r id wf_name run_name branch event status concl created; do
    i=$((i+1))
    ids+=("$id")
    printf "  [%2d] %-28s  %-30s  %-10s  %-18s  %-10s/%-10s  %s\n" \
      "$i" "$wf_name" "$run_name" "$branch" "$event" "$status" "$concl" "$created"
  done < <(printf '%s\n' "$lines")

  echo
  read -r -p "Enter number (1-$i) or run id: " choice
  echo

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= i )); then
    RUN_ID="${ids[$((choice-1))]}"
  else
    RUN_ID="$choice"
  fi

  rm -f "$tmp"
}

if [[ -z "$RUN_ID" ]]; then
  pick_run
fi

[[ "$RUN_ID" =~ ^[0-9]+$ ]] || die "Run id must be numeric; got: $RUN_ID"

repo_full="$(get_repo_full)"

# Fetch metadata for filename. Avoid requesting fields older gh versions may not support.
# If this fails, show the actual gh error.
meta="$(
  set +e
  "${ghcmd[@]}" run view "$RUN_ID" --json workflowName,name,headBranch,createdAt \
    --jq '[.workflowName, .name, .headBranch, .createdAt] | @tsv' 2> >(tee /dev/stderr)
  ec=$?
  set -e
  exit $ec
)" || die "gh run view failed for run id $RUN_ID in repo $repo_full."

IFS=$'\t' read -r wf_name run_name branch created_at <<<"$meta"

ts="$(date -u +"%Y%m%dT%H%M%SZ")"
repo_s="$(sanitize "$repo_full")"
wf_s="$(sanitize "$wf_name")"
br_s="$(sanitize "$branch")"

out_file="${OUT_DIR}/${repo_s}__${wf_s}__${br_s}__run-${RUN_ID}__${ts}.log"

echo "Downloading logs for run $RUN_ID..."
echo "Repo:      $repo_full"
echo "Workflow:  $wf_name"
echo "Branch:    $branch"
echo "Output:    $out_file"
echo

"${ghcmd[@]}" run view "$RUN_ID" --log --verbose > "$out_file"

echo "Done."
